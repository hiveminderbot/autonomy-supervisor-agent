age\\"][\\"completion_tokens\\"],\\n            \\"total_tokens\\": result[\\"usage\\"][\\"total_tokens\\"],\\n        },\\n    }\\n\\n# ---------------------------------------------------------------------------\\n# CLI\\n# ---------------------------------------------------------------------------\\n\\ndef main():\\n    if len(sys.argv) < 2:\\n        print(\\"Usage: python router.py \'<query>\'\\")\\n        print(\\"\\\\nExamples:\\")\\n        print(\'  python router.py \\"Find recent papers on LLM agents\\"\')\\n        print(\'  python router.py \\"Fix the bug in deduplicator.py\\"\')\\n        print(\'  python router.py \\"Generate an image of a cyberpunk city\\"\')\\n        sys.exit(1)\\n    \\n    query = sys.argv[1]\\n    result = classify_intent(query)\\n    \\n    print(json.dumps(result, indent=2))\\n\\nif __name__ == \\"__main__\\":\\n    main()\\n"}', name='read_file_tool', id='0865d475-e452-43c1-8a66-182309fb8f2b', tool_call_id='tool_read_file_tool_CNiVZeCFE0GFTA0GNTDa')]}}, 'thread_id': 'aad34df4-f7fb-461b-bb52-6cc8b03a7f42', 'max_test_cmd_retries': 3, 'max_tool_failures': 3, 'fallback_tool_model_limit': 5, 'retry_fallback_count': 3, 'test_cmd_timeout': 300, 'show_cost': False, 'track_cost': False, 'provider': 'openrouter', 'model': 'google/gemini-2.0-flash-001', 'num_ctx': 262144, 'expert_provider': 'openrouter', 'expert_model': 'google/gemini-2.0-flash-001', 'expert_num_ctx': 262144, 'temperature': 0.7, 'experimental_fallback_handler': False, 'web_research_enabled': False, 'show_thoughts': False, 'force_reasoning_assistance': False, 'disable_reasoning_assistance': True, 'custom_tools_enabled': False, 'cowboy_mode': True, 'research_only': False, 'use_aider': False, 'limit_tokens': True, 'auto_test': False, 'planner_provider': 'openrouter', 'planner_model': 'google/gemini-2.0-flash-001', 'research_provider': 'openrouter', 'research_model': 'google/gemini-2.0-flash-001', 'langgraph_step': 2, 'langgraph_node': 'tools', 'langgraph_triggers': ['__preg